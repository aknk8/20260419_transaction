# 開発環境（ローカル）用設定
# このファイルはリポジトリに含めてよい（開発用のダミー値のみ）

DATABASE_URL=postgres://app_user:app_password@localhost:5432/transaction_db_dev

# 開発用シークレット（本番では絶対に使用しないこと）
JWT_SECRET=dev-only-secret-not-for-production-use

PORT=3000
NODE_ENV=development

# フロントエンド開発サーバーのオリジン
CORS_ORIGIN=http://localhost:5173

# レートリミット（開発中は緩く設定）
RATE_LIMIT_MAX=1000

# 滞留承認チェック間隔（日数）
APPROVAL_STALE_DAYS=3

# ログレベル（development では debug 推奨）
LOG_LEVEL=debug
