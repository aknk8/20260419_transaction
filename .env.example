# データベース接続URL
DATABASE_URL=postgres://app_user:app_password@localhost:5432/transaction_db

# JWTシークレット（本番環境では必ず長いランダム文字列に変更すること）
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# サーバーポート
PORT=3000

# 実行環境（development / production）
NODE_ENV=development

# 統合テスト用データベース（npm run db:test:create で作成してから設定する）
# TEST_DATABASE_URL=postgres://app_user:app_password@localhost:5432/transaction_db_test
